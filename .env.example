# =============================================================
# EDULMS v2 — .env.example
#
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Replace every CHANGE_ME value (see notes inside each section).
#   3. NEVER commit .env. It is already in .gitignore — keep it that way.
#   4. Share .env with teammates ONLY through a private channel
#      (Telegram secret chat, 1Password share, signed message).
#      Not Slack, not email, not the group chat, not git.
# =============================================================


# ---------- General ----------
ENV=development
LOG_LEVEL=info


# ---------- gRPC ports (must not clash with v1 project on the VPS) ----------
AUTH_GRPC_PORT=50051
COURSE_GRPC_PORT=50052
ASSESSMENT_GRPC_PORT=50053


# ---------- API Gateway ----------
GATEWAY_HTTP_PORT=9080
GATEWAY_AUTH_TARGET=auth:50051
GATEWAY_COURSE_TARGET=course:50052
GATEWAY_ASSESSMENT_TARGET=assessment:50053


# ---------- Postgres (one DB per service, same instance) ----------
DB_URL=postgres://edulms:CHANGE_ME@postgres:5432/auth_v2?sslmode=disable
DATABASE_URL_COURSE=postgres://edulms:CHANGE_ME@postgres:5432/course_v2?sslmode=disable
DATABASE_URL_ASSESSMENT=postgres://edulms:CHANGE_ME@postgres:5432/assessment_v2?sslmode=disable
POSTGRES_USER=edulms
# Generate with:  openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5433


# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6380
CACHE_TTL_SECONDS=60
RATE_LIMIT_RPM=100


# ---------- NATS ----------
NATS_URL=nats://nats:4222
NATS_PORT=4222


# ---------- Notification + Mock Gateway ----------
GATEWAY_URL=http://mock-gateway:8090
MOCK_GATEWAY_PORT=8090
MOCK_GATEWAY_FAILURE_RATE=20
WORKER_POOL_SIZE=3
JOB_RETRY_ATTEMPTS=3
DLQ_KEY=dlq:notification
# Dev default is `mock` — talks to mock-gateway, never sends real email.
# Switch to `smtp` ONLY when demonstrating the SMTP path on defense.
MAILER=mock


# ---------- JWT ----------
# Generate each one with:  openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h


# =============================================================
# SMTP (Gmail) — READ THIS BEFORE FILLING IN
# =============================================================
#
# RULES YOU MUST FOLLOW (in this exact order):
#
#   1. DO NOT use your personal Gmail. Create a fresh throwaway
#      account, for example: edulms.notifications.<group>@gmail.com.
#      Reason: a Gmail App Password gives full SMTP + IMAP access
#      to that account. If the .env is ever leaked or pushed by
#      mistake, an attacker can read every email in that inbox and
#      send mail as that address. Burner account = blast radius is
#      zero.
#
#   2. On that throwaway account, TURN ON 2-Step Verification first.
#      Without 2FA, the "App passwords" page is hidden by Google.
#      https://myaccount.google.com/security  →  "2-Step Verification"
#
#   3. Generate an App Password (16 chars, looks like "abcd efgh ijkl mnop"):
#      https://myaccount.google.com/apppasswords
#      App = "Mail", Device = "Other → EDULMS v2 dev"
#      Copy the value, strip the spaces, paste into SMTP_PASSWORD below.
#
#   4. SMTP_USERNAME and SMTP_FROM must be the SAME address as the
#      one that generated the App Password. Gmail rejects messages
#      whose From: differs from the authenticated user (unless you
#      have configured an alias in Gmail Settings).
#
#   5. ROTATION SCHEDULE — set yourself a reminder:
#        • If the password ever appears anywhere outside this file
#          (chat, screenshot, terminal scrollback you didn't clear),
#          REVOKE IT IMMEDIATELY at the apppasswords URL above.
#        • Generate a fresh password right before the defense.
#        • Revoke that password right after the defense.
#      Old passwords stop working the moment you revoke them — no
#      cleanup needed beyond updating .env on whoever still uses it.
#
#   6. Keep MAILER=mock in dev. Flip to MAILER=smtp only when you are
#      actively demonstrating the SMTP path. This way a buggy unit
#      test can never spam the real inbox.
#
# AUDIT CHECKLIST FOR THE THROWAWAY GMAIL:
#   [ ] 2-Step Verification is ON
#   [ ] Recovery email + phone are set (so you can rescue the account)
#   [ ] No mail-forwarding rules configured
#   [ ] No "Less secure app access" enabled (it shouldn't be — 2FA blocks it)
#   [ ] No App Passwords other than the one for this project
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_PROJECT_GMAIL_ADDRESS
SMTP_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD_NO_SPACES
SMTP_FROM=EDULMS <CHANGE_ME_PROJECT_GMAIL_ADDRESS>
SMTP_STARTTLS=true
# =============================================================


# ---------- Observability ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME is set per-service in each docker-compose service block.


# ---------- Grafana ----------
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
# Generate with:  openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=CHANGE_ME


# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:9080
WEB_PORT=4000
